{
  "name": "PikaOS Development Environment",
  "image": "git.pika-os.com/repo-tools/docker-images/pikaos-builder:nestv3", 
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "installOhMyZsh": true,
      "upgradePackages": true
    },
    "ghcr.io/devcontainers/features/git:1": {},
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh"
      },
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.remote-explorer"
      ]
    }
  },
  "forwardPorts": [],
  "postCreateCommand": "echo 'Welcome To PikaOS' && uname -a",
  "remoteUser": "mysticgiggle"
}
